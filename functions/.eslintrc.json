{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "no-empty": "warn",
    "no-inner-declarations": "off",
    "no-useless-escape": "off"
  }
}
